# Upstash Redis REST credentials (server-side only, never exposed to browser)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Optional: restrict iframe embedding to your blog domain
# Leave unset during development (defaults to 'self' only)
# Example: https://your-blog.pages.dev
BLOG_DOMAIN=
